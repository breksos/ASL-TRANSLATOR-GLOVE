# ===== ASL Glove — .gitignore =====

# ---- Flutter / Dart build artifacts (regenerated by `flutter build`) ----
flutter_app/build/
flutter_app/.dart_tool/
flutter_app/.flutter-plugins
flutter_app/.flutter-plugins-dependencies
flutter_app/.packages
flutter_app/.pub-cache/
flutter_app/.pub/
flutter_app/android/.gradle/
flutter_app/android/app/build/
flutter_app/android/build/
flutter_app/ios/Pods/
flutter_app/ios/.symlinks/
flutter_app/build/
**/*.iml
**/.idea/

# ---- Derived datasets (regenerate via scripts/: relative_features.py,
#      augment_calibration.py). Raw recordings (scripts/data, scripts/data_words)
#      ARE kept. ----
scripts/data_rel/
scripts/data_rel_aug/
scripts/data_words_rel/
scripts/data_words_rel_aug/
scripts/data_words_abs_aug/
scripts/data_letters_abs_aug/
scripts/data_backup_absolute/
scripts/data_old/
scripts/dataold/

# ---- Python ----
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.ipynb_checkpoints/

# ---- Arduino / PlatformIO build output ----
firmware/**/build/
.pio/

# ---- LaTeX build artifacts ----
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
"Graduation Project - Latex Template"/*.pdf

# ---- OS / editor ----
.DS_Store
Thumbs.db
*.swp
*~

# ---- Logs ----
*.log
_sniff.log

# ---- Local tooling / editor / redundant archives ----
.claude/
.vscode/
.clangd
*.zip
.history/
*-backups/
fp-info-cache
*-bak
*.kicad_prl

